# Base distante PostgreSQL contenant le schéma analytics
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Schéma PostgreSQL cible pour les données métier
DB_SCHEMA="analytics"

# [OPTIONNEL] Connexion séparée pour le schéma audit_management (anomalies)
# Si non défini, utilise DATABASE_URL (même serveur, schéma différent)
# Si défini, permet d'utiliser un serveur PostgreSQL complètement différent pour les anomalies
# AUDIT_POSTGRES_URL="postgresql://USER:PASSWORD@HOST:5432/AUDIT_DB?sslmode=require"

# Mettre true si le serveur PostgreSQL impose SSL.
# Sur Vercel, conservez généralement true avec sslmode=require dans DATABASE_URL.
PGSSL="true"

# Limite maximale de lignes retournées par rubrique
DEFAULT_LIMIT="200"
