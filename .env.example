# Base distante PostgreSQL contenant le schéma analytics
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require"

# Schéma PostgreSQL cible
DB_SCHEMA="analytics"

# Mettre true si le serveur PostgreSQL impose SSL.
# Sur Vercel, conservez généralement true avec sslmode=require dans DATABASE_URL.
PGSSL="true"

# Limite maximale de lignes retournées par rubrique
DEFAULT_LIMIT="200"
