{
    "version": 2,
    "name": "financeaudit-analytics-nextjs",
    "builds": [{
        "src": "package.json",
        "use": "@vercel/next"
    }],
    "routes": [{
            "src": "/api/(.*)",
            "dest": "/api/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}